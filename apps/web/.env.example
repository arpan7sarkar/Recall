# Next.js sets NODE_ENV automatically:
# - `npm run dev` -> development
# - `npm run build && npm run start` -> production

# Development backend (local API)
NEXT_PUBLIC_API_URL_DEV=http://localhost:4000/v1

# Production backend (Render API)
NEXT_PUBLIC_RENDER_API_URL=https://your-api-name.onrender.com/v1

# Backward-compatibility fallback (optional)
# NEXT_PUBLIC_API_URL=

NEXT_PUBLIC_MAX_UPLOAD_MB=20
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
